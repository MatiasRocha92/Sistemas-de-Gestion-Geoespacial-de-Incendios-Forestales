# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS (PostgreSQL + PostGIS)
# =============================================================================
POSTGRES_USER=firewatch
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=firewatch_db
POSTGRES_PORT=5432

# =============================================================================
# CONFIGURACIÓN DE REDIS
# =============================================================================
REDIS_PORT=6379

# =============================================================================
# API KEYS EXTERNAS
# =============================================================================
# NASA FIRMS - Obtener en: https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_API_KEY=your_nasa_firms_api_key

# Open-Meteo (Gratuito para uso no comercial)
OPEN_METEO_API_KEY=

# Telegram Bot Token - Obtener con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# =============================================================================
# CONFIGURACIÓN DEL BACKEND
# =============================================================================
SECRET_KEY=your_super_secret_key_change_in_production
DEBUG=true
ENVIRONMENT=development
BACKEND_PORT=8000

# CORS Origins (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# CONFIGURACIÓN DEL FRONTEND
# =============================================================================
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
